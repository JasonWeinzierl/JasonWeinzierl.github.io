---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en-US">
<head>
    <BaseHead title="Jason Weinzierl | Education" />
</head>

<body>
    <Header />
    <main>
        <div class="container mx-auto px-3 mt-6">
            <h1 class="mb-2">Jason Weinzierl &mdash; Education</h1>
            <p class="text-xl font-light mb-4">Graduate of the University of Missouri</p>
            <ul class="list-disc list-inside">
              <li class="text-xl">Computer Science, Minor</li>
              <li class="text-xl">Physics, B.S.</li>
              <li class="text-xl">Mathematics, B.S.</li>
            </ul>
        </div>
    </main>
    <Footer />
</body>
</html>
