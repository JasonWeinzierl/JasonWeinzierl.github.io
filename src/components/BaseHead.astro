---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<meta charset="utf-8" />
<meta name="author" content="Jason Weinzierl" />
<meta name="description" content="Jason Weinzierl is a developer" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<link rel="sitemap" href="/sitemap-index.xml" />

<title>{title}</title>
